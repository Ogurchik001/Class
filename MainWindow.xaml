<Window x:Class="Lukianov_Class.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lukianov_Class"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition Height="20"/>
                <RowDefinition/>
                <RowDefinition  Height="20"/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Button Name="J"  Grid.Row="1" Content="Журнал" Width="90" Height="50" Margin="5" Click="J_Click"/>

            <Button Name="O" Grid.Row="3" Content="Отчет 1" Width="90" Height="50" Margin="5" Click="O_Click"/>

            <Button Name="Ot" Grid.Row="5" Content="Отчет 2" Width="90" Height="50" Margin="5" Click="Ot_Click"/>
        </Grid>
        <Frame Name="MainFrame"  Grid.Column="1"/>

    </Grid>
</Window>
