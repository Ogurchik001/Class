<Page x:Class="Lukianov_Class.Views.Pages.JournalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lukianov_Class.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="JournalPage" Foreground="#FF060606">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите дату" Name="DateTb" VerticalAlignment="Center" FontSize="25"/>
        <DatePicker Grid.Column="1" FontSize="25" Name="DateDp"  VerticalAlignment="Center"/>

        <TextBlock Text="Выберите класс" Name="ClassTb" VerticalAlignment="Center" FontSize="25" Grid.Row="2"/>
        <ComboBox Name="ClassCmb" Grid.Row="2" Grid.Column="1" Margin="0 5 0 5"/>

        <TextBlock Text="Введите кг" Name="KgTb" VerticalAlignment="Center" FontSize="25" Grid.Row="4"/>
        <TextBox Grid.Column="1" Grid.Row="4" Margin="0 5 0 5" FontSize="25"/>

        <Button Grid.Row="6" Grid.Column="2" Margin="20 5 20 5" Click="Button_Click" Content="Добавить" FontSize="20"/>

        <ListView Name="JournalLV" Grid.ColumnSpan="3" Grid.Row="7">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding DateEvent, StringFormat=dd.MM.yyyy}"/>
                    <GridViewColumn Header="Параллель" DisplayMemberBinding="{Binding Class.Parallel.Name}"/>
                    <GridViewColumn Header="Класс" DisplayMemberBinding="{Binding Class.Name}"/>
                    <GridViewColumn Header="КГ" DisplayMemberBinding="{Binding KiloFlourPaper}"/>
                    </GridView>
            </ListView.View>
        </ListView>


    </Grid>
</Page>
